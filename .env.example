# Copy to .env.local (never commit .env.local).
# Vercel: mirror the same keys into Project → Settings → Environment Variables,
# and scope Preview values to the `staging` git branch where applicable.

# Supabase public client keys — set per environment.
# Production → prod project URL + anon key
# Preview/staging → staging branch URL + anon key (from Supabase Branching)
# Dev local → whichever project you're pointing at
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Which environment this build represents. Drives the staging banner.
# Allowed: production | staging | preview | development
# Leave unset (or set to "production") for prod builds — banner hides itself.
VITE_WAYA_ENV=development

# Sentry (client) — optional
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# ─── Edge Function secrets (NOT for this file) ────────────────────────────────
# The Admin Design Studio (/admin/design-studio) calls Google Gemini server-side.
# The key is stored as a Supabase Edge Function secret, never in the browser bundle:
#   supabase secrets set GEMINI_API_KEY=AIza...
# Optional overrides (defaults are gemini-2.5-flash + gemini-2.5-flash-image):
#   supabase secrets set GEMINI_TEXT_MODEL=gemini-2.5-flash
#   supabase secrets set GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Get a free-tier key at https://aistudio.google.com/app/apikey
